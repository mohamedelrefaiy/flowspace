{
  "name": "flowspace",
  "private": false,
  "version": "1.2.6",
  "type": "module",
  "bin": {
    "flowspace": "bin/cli.mjs"
  },
  "files": [
    "bin/cli.mjs",
    "dist/",
    "dist-server/server.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "tw:build": "tailwindcss -i src/tailwind.input.css -o src/tailwind.generated.css",
    "tw:watch": "tailwindcss -i src/tailwind.input.css -o src/tailwind.generated.css --watch",
    "dev": "concurrently \"npm run tw:watch\" \"tsx server.ts\"",
    "build:cli": "esbuild bin/cli.ts --bundle --platform=node --format=esm --outfile=bin/cli.mjs --target=node20",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist-server/server.mjs --target=node20 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --define:__FLOWSPACE_VERSION__=\\\"$npm_package_version\\\"",
    "build": "npm run tw:build && vite build",
    "build:all": "npm run build && npm run build:server && npx esbuild bin/cli.ts --bundle --platform=node --format=esm --outfile=bin/cli.mjs --target=node20 --external:@clack/prompts",
    "prepare:desktop-sidecars": "node scripts/bundle-desktop-sidecars.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run prepare:desktop-sidecars && tauri build"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@clack/prompts": "^1.1.0",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "debug": "2.6.9",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@googleworkspace/cli": "^0.4.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.5",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
